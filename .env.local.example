# Moonshot Kimi K2.6 API key — https://platform.kimi.ai/
# Required. The whole pipeline (orchestrator + all sub-agents) runs on Kimi K2.6.
MOONSHOT_API_KEY=

# Central Icons license key — required to install `@central-icons-react/*`
# packages. Get yours from https://iconists.co/central.
#
# IMPORTANT: must be exported in your shell BEFORE `npm install`:
#     export CENTRAL_LICENSE_KEY=...
# The package's preinstall hook runs before Next.js loads .env.local.
CENTRAL_LICENSE_KEY=
